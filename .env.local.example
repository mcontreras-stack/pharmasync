# =============================================================================
# PharmaSync — Variables de entorno
# Copia este archivo como `.env.local` (local) o define las variables en tu
# servidor/panel de despliegue (Railway, VPS, Docker, etc.)
# =============================================================================

# ─── OPCIÓN A: Supabase ──────────────────────────────────────────────────────
# Supabase Studio > Project Settings > API
# Ejecuta antes database/setup-supabase.sql en el SQL Editor.
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=TU_ANON_KEY

# Service role (SOLO en el servidor, nunca en el navegador). Habilita en el
# panel de admin: crear usuarios, resetear contraseñas y eliminar cuentas.
SUPABASE_SERVICE_ROLE_KEY=TU_SERVICE_ROLE_KEY

# ─── OPCIÓN B: PostgreSQL directo (tu propio servidor) ───────────────────────
# Ejecuta antes database/setup-postgres.sql en tu base de datos.
# Usuario admin inicial: admin@pharmasync.local / cambiar123
#DATABASE_URL=postgresql://usuario:password@localhost:5432/pharmasync
#DATABASE_SSL=false
# Obligatorio en modo PostgreSQL para que el navegador use las rutas /api:
#NEXT_PUBLIC_DATA_BACKEND=postgres

# ─── Sin ninguna de las dos opciones ─────────────────────────────────────────
# La app corre en MODO DEMO (datos mock en localStorage, contraseña 123456).

# URL pública del sitio (para enlaces de correos de Supabase)
#NEXT_PUBLIC_SITE_URL=https://tu-dominio.com
